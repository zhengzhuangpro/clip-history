{
  "$schema": "https://raw.githubusercontent.com/nicoverbruggen/tauri-v2-schema/main/schema.json",
  "productName": "Clip History",
  "version": "0.1.4",
  "identifier": "com.clip-history.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Clip History",
        "width": 400,
        "height": 600,
        "minWidth": 360,
        "minHeight": 400,
        "decorations": true,
        "resizable": true,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": "zh-CN"
      },
      "nsis": {
        "languages": ["SimpChinese", "English"],
        "displayLanguageSelector": false
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IERBFjhDQUE5MDIyRjgwNDYKUldSR2dDOENxYy80MnREREtsQVU4eExnU09SMkxOSjcrTy9pRGRpekIrSTVRM2x4Ykh1M0NiZngK",
      "endpoints": [
        "https://github.com/zhengzhuangpro/clip-history/releases/latest/download/latest.json"
      ]
    }
  }
}
