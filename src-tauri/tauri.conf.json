{
  "$schema": "https://raw.githubusercontent.com/nicoverbruggen/tauri-v2-schema/main/schema.json",
  "productName": "Clip History",
  "version": "0.1.0",
  "identifier": "com.clip-history.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Clip History",
        "width": 400,
        "height": 600,
        "minWidth": 360,
        "minHeight": 400,
        "decorations": true,
        "resizable": true,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/zhengzhuangpro/clip-history/releases/latest/download/{{target}}/{{arch}}/{{current_version}}"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM3RDgyNUNDNUEzNkQ2RDYKUldUVzFqWmF6Q1hZeDFwYU45Z2p5STU3MHM0L0JyNkJsV0ExYy9vVlkybGRYZi9hL1lSVGZHZUYK"
    }
  }
}
